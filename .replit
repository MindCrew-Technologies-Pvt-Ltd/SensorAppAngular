modules = ["nodejs-22"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Angular Server"

[[workflows.workflow]]
name = "Angular Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd angular-app && npm start"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 41419
externalPort = 3000
